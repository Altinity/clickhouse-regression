<?xml version="1.0"?>
<!--
    EXPORT PARTITION's commit/write phase runs on a *background* context that
    ClickHouse builds in
    ``ExportPartitionUtils::getContextCopyWithTaskSettings`` by copying
    ``storage.getContext()`` (the server context) and then forwarding only a
    small whitelist of per-task knobs from the manifest. The whitelist does
    NOT include ``allow_experimental_insert_into_iceberg``, so the gate
    inside ``IcebergMetadata::write`` always throws unless the setting is
    already part of the default user profile that the server context
    inherits. Without this overlay the background scheduler catches each
    throw, bumps ``commit_attempts``, and the export sits in PENDING until
    the per-task retry budget is exhausted - far past the suite's per-step
    waits.

    Unlike ``allow_experimental_export_merge_tree_partition`` (registered in
    ``ServerSettings.cpp`` and therefore honoured at config root), this is
    a regular per-query ``Setting`` (declared in ``Settings.cpp``) and must
    be set inside a profile to take effect.

    The synchronous EXPORT PARTITION call also re-checks this setting in
    ``StorageReplicatedMergeTree::exportPartitionToTable``; this overlay
    covers that gate too, so the per-query injection in
    ``prepare_export_partition_settings`` is now belt-and-braces.
-->
<clickhouse>
    <profiles>
        <default>
            <allow_experimental_insert_into_iceberg>1</allow_experimental_insert_into_iceberg>
        </default>
    </profiles>
</clickhouse>
